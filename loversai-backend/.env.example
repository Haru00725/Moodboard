# =============================================
# LoversAI Backend — Environment Configuration
# =============================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://loversai:Loversaicluster0.drhae.mongodb.net/loversai?appName=Cluster0

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- AI API (infip) ---
INFIP_API_KEY=your_infip_api_key_here
INFIP_BASE_URL=https://api.infip.pro/v1
INFIP_MODEL=flux-pro
INFIP_POLL_INTERVAL_MS=3000
INFIP_MAX_RETRIES=5
INFIP_POLL_TIMEOUT_MS=120000

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=10

# --- Credits ---
FREE_PLAN_CREDITS=1
PRO_PLAN_CREDITS=3
REFERRAL_BONUS_CREDITS=5

# --- Base URL (for serving uploaded files) ---
BASE_URL=http://localhost:5000
